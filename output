@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');
@import "tailwindcss";

/* ── Brand token definitions ──────────────────────────────────── */
:root {
  --color-espresso:   #1A0F07;
  --color-roast:      #2C1810;
  --color-mahogany:   #4A2515;
  --color-terracotta: #C1440E;
  --color-amber:      #D4824A;
  --color-gold:       #C9952A;
  --color-forest:     #1E3A2F;
  --color-sage:       #4A7C59;
  --color-mist:       #A8C5A0;
  --color-cream:      #F5EDD8;
  --color-parchment:  #EDE0C4;
  --color-border:     rgba(245,237,216,0.08);
  --color-border-strong: rgba(245,237,216,0.15);
  --sidebar-width: 260px;
  --sidebar-collapsed-width: 64px;
  --topbar-height: 56px;
  color-scheme: dark;
}

/* ── Tailwind v4 theme tokens ─────────────────────────────────── */
@theme {
  --color-espresso:   #1A0F07;
  --color-roast:      #2C1810;
  --color-mahogany:   #4A2515;
  --color-terracotta: #C1440E;
  --color-amber:      #D4824A;
  --color-gold:       #C9952A;
  --color-forest:     #1E3A2F;
  --color-sage:       #4A7C59;
  --color-mist:       #A8C5A0;
  --color-cream:      #F5EDD8;
  --color-parchment:  #EDE0C4;
  --color-border:     rgba(245,237,216,0.08);
  --color-border-strong: rgba(245,237,216,0.15);

  --font-display: "Cormorant Garamond", Georgia, serif;
  --font-mono:    "DM Mono", monospace;
  --font-sans:    "Instrument Sans", sans-serif;

  --text-2xs: 0.625rem;
  --text-2xs--line-height: 1rem;

  --radius-sm: 2px;
  --radius-md: 4px;
  --radius-lg: 6px;

  --spacing-18: 4.5rem;
}

/* ── Reset ────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

body {
  margin: 0;
  background: #1A0F07;
  color: #F5EDD8;
  font-family: "Instrument Sans", sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ── Grain texture overlay ────────────────────────────────────── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 9999;
  opacity: 0.3;
}

/* ── Scrollbar ────────────────────────────────────────────────── */
::-webkit-scrollbar       { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(245,237,216,0.12); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: rgba(245,237,216,0.2); }

/* ── Focus ────────────────────────────────────────────────────── */
*:focus-visible { outline: 1px solid #C1440E; outline-offset: 2px; }

/* ── Component classes ────────────────────────────────────────── */
@layer components {

  /* Card — the main surface unit */
  .card {
    background: #2C1810;
    border: 1px solid rgba(245,237,216,0.08);
    border-radius: 4px;
  }

  .card-title {
    font-family: "DM Mono", monospace;
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,237,216,0.35);
    margin: 0 0 16px;
  }

  /* Subtle inner card */
  .card-inner {
    background: rgba(26,15,7,0.5);
    border: 1px solid rgba(245,237,216,0.06);
    border-radius: 2px;
  }

  /* Stat value */
  .stat-value {
    font-family: "Cormorant Garamond", serif;
    font-size: 2.5rem;
    font-weight: 300;
    line-height: 1;
  }

  /* Pill / badge */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 20px;
    font-family: "DM Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  /* Primary action button */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 2px;
    background: rgba(193,68,14,0.15);
    border: 1px solid rgba(193,68,14,0.35);
    color: #C1440E;
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-primary:hover {
    background: rgba(193,68,14,0.25);
    border-color: rgba(193,68,14,0.5);
  }

  /* Ghost button */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 2px;
    background: transparent;
    border: 1px solid rgba(245,237,216,0.08);
    color: rgba(245,237,216,0.5);
    font-family: "DM Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all 0.15s;
  }
  .btn-ghost:hover {
    border-color: rgba(245,237,216,0.15);
    color: rgba(245,237,216,0.8);
  }

  /* Table row */
  .table-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 2px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all 0.15s;
  }
  .table-row:hover {
    background: rgba(245,237,216,0.02);
    border-color: rgba(245,237,216,0.06);
  }

  /* Section divider */
  .divider {
    border: none;
    border-top: 1px solid rgba(245,237,216,0.08);
    margin: 16px 0;
  }

  /* Input */
  .input {
    width: 100%;
    background: #1A0F07;
    border: 1px solid rgba(245,237,216,0.1);
    border-radius: 2px;
    padding: 8px 12px;
    color: #F5EDD8;
    font-family: "Instrument Sans", sans-serif;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .input:focus {
    border-color: rgba(193,68,14,0.5);
  }
  .input::placeholder {
    color: rgba(245,237,216,0.2);
  }

  /* Label */
  .label {
    display: block;
    font-family: "DM Mono", monospace;
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245,237,216,0.35);
    margin-bottom: 6px;
  }

  /* Page header */
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.75rem;
    font-weight: 400;
    color: #F5EDD8;
    margin: 0 0 4px;
    line-height: 1.2;
  }

  .page-subtitle {
    font-family: "DM Mono", monospace;
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(245,237,216,0.25);
    margin: 0;
  }
}

/* ── Utility extensions ───────────────────────────────────────── */
@layer utilities {
  .text-2xs {
    font-size: 0.625rem;
    line-height: 1rem;
  }

  .border-border {
    border-color: rgba(245,237,216,0.08);
  }

  .border-border-strong {
    border-color: rgba(245,237,216,0.15);
  }

  .bg-white\/3 {
    background-color: rgba(255,255,255,0.03);
  }

  .font-display {
    font-family: "Cormorant Garamond", Georgia, serif;
  }

  .font-mono {
    font-family: "DM Mono", monospace;
  }

  .tracking-widest {
    letter-spacing: 0.2em;
  }
}
